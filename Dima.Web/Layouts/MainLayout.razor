@using Dima.Web.Components
@using Dima.Core.Handlers
@using Dima.Core.Requests.Account
@using Dima.Core.Responses.Account
@inherits LayoutComponentBase
@implements IDisposable
@inject IProfileHandler ProfileHandler

<MudThemeProvider
    @ref="_mudThemeProvider"
    @bind-IsDarkMode="_isDarkMode"
    Theme="Configuration.Theme"/>
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<AuthorizeView>
    <Authorized>
        <MudLayout>
            <MudAppBar Elevation="0" Class="dima-appbar">
                <MudIconButton
                    Icon="@Icons.Material.Outlined.Menu"
                    Color="Color.Inherit"
                    Edge="Edge.Start"
                    OnClick="@((e) => DrawerToggle())"
                    Class="mr-1" />

                <MudImage Src="img/logo_dark.png" Alt="Dima" Height="30" Class="ml-1" />

                <MudSpacer />

                <MudIconButton
                    Icon="@(_isDarkMode ? Icons.Material.Outlined.LightMode : Icons.Material.Outlined.DarkMode)"
                    Color="Color.Inherit"
                    OnClick="ToggleDarkMode"
                    Class="mr-1"
                    Title="@(_isDarkMode ? "Modo Claro" : "Modo Escuro")" />

                <MudMenu AnchorOrigin="Origin.BottomRight" TransformOrigin="Origin.TopRight" Dense="true">
                    <ActivatorContent>
                        <div class="d-flex align-center gap-2 dima-user-trigger">
                            <MudHidden Breakpoint="Breakpoint.SmAndDown">
                                <div class="d-flex flex-column align-end">
                                    <MudText Typo="Typo.body2" Style="font-weight: 600; line-height: 1.2;">
                                        @GetUserName(context.User.Identity?.Name)
                                    </MudText>
                                    <MudText Typo="Typo.caption" Style="opacity: 0.6; font-size: 0.7rem;">
                                        @(_profile?.IsPremium == true ? "Premium" : "Plano Free")
                                    </MudText>
                                </div>
                            </MudHidden>
                            <MudBadge
                                Visible="@(_profile?.IsPremium == true)"
                                Icon="@Icons.Material.Filled.Star"
                                Color="Color.Warning"
                                Overlap="true"
                                Bordered="true">
                                <MudAvatar
                                    Style="background: var(--dima-cyan); color: white; font-weight: 700; font-size: 0.875rem; width: 36px; height: 36px;">
                                    @GetUserInitial(context.User.Identity?.Name)
                                </MudAvatar>
                            </MudBadge>
                        </div>
                    </ActivatorContent>
                    <ChildContent>
                        <div class="px-4 py-3 dima-menu-header">
                            <MudText Typo="Typo.body2" Style="font-weight: 700;">
                                @(_profile?.Name ?? GetUserName(context.User.Identity?.Name))
                            </MudText>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @context.User.Identity?.Name
                            </MudText>
                            @if (_profile?.IsPremium == true)
                            {
                                <span class="badge-warning mt-1" style="font-size: 0.65rem;">
                                    ★ Premium
                                </span>
                            }
                        </div>
                        <MudDivider />
                        <MudMenuItem Icon="@Icons.Material.Outlined.Person" Href="/settings/me">
                            Minha Conta
                        </MudMenuItem>
                        <MudMenuItem
                            Icon="@(_isDarkMode ? Icons.Material.Outlined.LightMode : Icons.Material.Outlined.DarkMode)"
                            OnClick="ToggleDarkMode">
                            @(_isDarkMode ? "Modo Claro" : "Modo Escuro")
                        </MudMenuItem>
                        <MudDivider />
                        <MudMenuItem Icon="@Icons.Material.Outlined.Logout" Href="/logout">
                            Sair
                        </MudMenuItem>
                    </ChildContent>
                </MudMenu>
            </MudAppBar>

            <MudDrawer
                @bind-Open="_drawerOpen"
                ClipMode="DrawerClipMode.Always"
                Elevation="0"
                Variant="@DrawerVariant.Responsive"
                Width="230px"
                Class="dima-drawer">
                <NavMenu IsPremium="@(_profile?.IsPremium ?? false)" />
            </MudDrawer>

            <MudMainContent Class="dima-main-content">
                <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pt-8 pb-10 px-6">
                    <CascadingValue Value="_isDarkMode">
                        @Body
                    </CascadingValue>
                </MudContainer>
            </MudMainContent>
        </MudLayout>
    </Authorized>
    <NotAuthorized>
        <LoginRedirect />
    </NotAuthorized>
</AuthorizeView>

<style>
    .dima-appbar {
        border-bottom: 1px solid var(--mud-palette-divider) !important;
        backdrop-filter: blur(8px);
    }

    .dima-drawer {
        border-right: 1px solid var(--mud-palette-divider) !important;
    }

    .dima-main-content {
        background-color: var(--mud-palette-background);
        min-height: 100vh;
    }

    .dima-user-trigger {
        cursor: pointer;
        padding: 4px 8px;
        border-radius: 8px;
        transition: background 0.15s ease;
    }

    .dima-user-trigger:hover {
        background: rgba(255, 255, 255, 0.08);
    }

    .dima-menu-header {
        min-width: 200px;
    }
</style>

@code {

    private bool _isDarkMode = true;
    private bool _drawerOpen = true;
    private MudThemeProvider _mudThemeProvider = null!;
    private GetProfileResponse? _profile;

    [CascadingParameter]
    private Task<AuthenticationState> AuthenticationStateTask { get; set; } = null!;

    private void DrawerToggle()
    {
        _drawerOpen = !_drawerOpen;
    }

    private void ToggleDarkMode()
    {
        _isDarkMode = !_isDarkMode;
    }

    private string GetUserName(string? identityName)
    {
        if (_profile is not null && !string.IsNullOrEmpty(_profile.Name))
            return _profile.Name;

        if (string.IsNullOrEmpty(identityName)) return "Usuário";
        var index = identityName.IndexOf('@');
        return index > 0 ? identityName[..index] : identityName;
    }

    private string GetUserInitial(string? identityName)
    {
        if (_profile is not null && !string.IsNullOrEmpty(_profile.Name))
            return _profile.Name[0].ToString().ToUpper();

        if (string.IsNullOrEmpty(identityName)) return "U";
        return identityName[0].ToString().ToUpper();
    }

    protected override async Task OnInitializedAsync()
    {
        ProfileHandler.OnChange += HandleProfileChange;
        await GetProfileAsync();
    }

    private async void HandleProfileChange()
    {
        await GetProfileAsync();
        StateHasChanged();
    }

    private async Task GetProfileAsync()
    {
        var authState = await AuthenticationStateTask;
        var user = authState.User;

        if (user.Identity is { IsAuthenticated: true })
        {
            var result = await ProfileHandler.GetProfileAsync(new GetProfileRequest());
            if (result.IsSuccess)
            {
                _profile = result.Data;
            }
        }
    }

    public void Dispose()
    {
        ProfileHandler.OnChange -= HandleProfileChange;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _isDarkMode = await _mudThemeProvider.GetSystemDarkModeAsync();
            StateHasChanged();
        }
    }
}
