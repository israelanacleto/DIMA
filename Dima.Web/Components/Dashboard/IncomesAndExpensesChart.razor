
<MudCard Elevation="25" Class="animate-slide-up">
    <MudCardHeader>
        <CardHeaderContent>
            <MudText Typo="Typo.h6">Entradas e Saídas</MudText>
        </CardHeaderContent>
    </MudCardHeader>
    <MudCardContent>
        @if (IsLoading)
        {
            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="350px" />
        }
        else
        {
            <div class="animate-fade-in">
                <MudChart ChartType="ChartType.Bar"
                          ChartSeries="@Series"
                          XAxisLabels="@Labels"
                          ChartOptions="@Options"
                          Width="100%"
                          Height="350px"
                          Animation="true"/>
            </div>
        }
    </MudCardContent>
</MudCard>
