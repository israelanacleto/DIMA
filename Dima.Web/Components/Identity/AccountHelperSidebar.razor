<MudItem xs="12" md="4">
    <div class="d-flex flex-column gap-4">
        <MudCard Elevation="0" Style="border-radius: 16px; background: color-mix(in srgb, var(--mud-palette-tertiary), transparent 92%);" Class="pa-8">
            <MudIcon Icon="@Icons.Material.Filled.Shield" Color="Color.Tertiary" Style="font-size: 2.5rem;" Class="mb-4" />
            <MudText Typo="Typo.h6" GutterBottom="true" Style="font-weight: 700;">Segurança</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Style="line-height: 1.6;">
                Mantenha sua senha atualizada e evite usar a mesma senha em outros serviços. Uma senha forte contém letras, números e símbolos.
            </MudText>
        </MudCard>

        <MudCard Elevation="0" Style="border-radius: 16px; border: 2px dashed var(--mud-palette-divider); background: transparent;" Class="pa-8">
            <MudIcon Icon="@Icons.Material.Filled.ContactMail" Color="Color.Info" Style="font-size: 2.5rem;" Class="mb-4" />
            <MudText Typo="Typo.h6" GutterBottom="true" Style="font-weight: 700;">Dados de Contato</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Style="line-height: 1.6;">
                Seu e-mail e nome de usuário são únicos e não podem ser alterados. Eles são fundamentais para sua identificação no sistema.
            </MudText>
        </MudCard>
    </div>
</MudItem>
