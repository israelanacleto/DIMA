@inject NavigationManager NavigationManager

<div class="redirect-wrap animate-fade-in">
    <div class="redirect-inner">
        <div class="redirect-logo">
            <img src="img/logo_dark.png" alt="Dima" height="44" />
        </div>

        <MudProgressCircular
            Color="Color.Secondary"
            Indeterminate="true"
            Size="Size.Small"
            Class="redirect-spinner" />

        <MudText Typo="Typo.h6" Style="font-weight: 600; letter-spacing: -0.01em;">
            Redirecionando...
        </MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            Você será enviado para o login em instantes.
        </MudText>
    </div>
</div>

<style>
    .redirect-wrap {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        background: var(--mud-palette-background);
    }

    .redirect-inner {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
        text-align: center;
        padding: 2rem;
    }

    .redirect-logo {
        margin-bottom: 0.5rem;
        opacity: 0.8;
    }

    .redirect-spinner {
        margin: 0.25rem 0;
    }
</style>

@code
{
    [CascadingParameter]
    public bool IsDarkMode { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await Task.Delay(1500);
        NavigationManager.NavigateTo("/login");
    }
}
