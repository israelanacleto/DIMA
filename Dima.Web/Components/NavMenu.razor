@namespace Dima.Web.Components

<div class="dima-nav">

    <div class="nav-section">
        <span class="nav-section-label">Principal</span>
        <MudNavLink
            Match="NavLinkMatch.All"
            Icon="@Icons.Material.Outlined.Dashboard"
            Href="/dashboard"
            Class="dima-nav-link">
            Dashboard
        </MudNavLink>
        <MudNavLink
            Match="NavLinkMatch.Prefix"
            Icon="@Icons.Material.Outlined.AccountBalanceWallet"
            Href="/transactions"
            Class="dima-nav-link">
            Lançamentos
        </MudNavLink>
        <MudNavLink
            Match="NavLinkMatch.Prefix"
            Icon="@Icons.Material.Outlined.Category"
            Href="/categories"
            Class="dima-nav-link">
            Categorias
        </MudNavLink>
    </div>

    <div class="nav-section">
        <span class="nav-section-label">Assinaturas</span>
        @if (IsPremium)
        {
            <MudNavLink
                Match="NavLinkMatch.Prefix"
                Icon="@Icons.Material.Outlined.List"
                Href="/orders"
                Class="dima-nav-link">
                Meus Planos
            </MudNavLink>
        }
        else
        {
            <MudNavLink
                Match="NavLinkMatch.Prefix"
                Icon="@Icons.Material.Outlined.WorkspacePremium"
                Href="/plans"
                Class="dima-nav-link">
                Planos
            </MudNavLink>
            <MudNavLink
                Match="NavLinkMatch.Prefix"
                Icon="@Icons.Material.Outlined.ReceiptLong"
                Href="/orders"
                Class="dima-nav-link">
                Meus Pedidos
            </MudNavLink>
        }
    </div>

    <div class="nav-section">
        <span class="nav-section-label">Conta</span>
        <MudNavLink
            Match="NavLinkMatch.Prefix"
            Icon="@Icons.Material.Outlined.ManageAccounts"
            Href="/settings/me"
            Class="dima-nav-link">
            Minha Conta
        </MudNavLink>
        <MudNavLink
            Match="NavLinkMatch.Prefix"
            Icon="@Icons.Material.Outlined.HelpOutline"
            Href="/help"
            Class="dima-nav-link">
            Ajuda & Docs
        </MudNavLink>
    </div>

</div>

<style>
    .dima-nav {
        display: flex;
        flex-direction: column;
        padding: 1rem 0;
        gap: 0.25rem;
        height: 100%;
    }

    .nav-section {
        display: flex;
        flex-direction: column;
        padding: 0 0.75rem;
        margin-bottom: 0.5rem;
    }

    .nav-section-label {
        font-size: 0.65rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--mud-palette-drawer-icon);
        padding: 1rem 0.75rem 0.375rem;
        display: block;
    }

    /* Override MudNavLink para o estilo DIMA */
    .dima-nav .mud-nav-link {
        border-radius: 4px !important;
        margin: 4px 8px !important;
        padding: 8px 12px !important;
        font-size: 0.875rem !important;
        font-weight: 500 !important;
        transition: all 0.15s ease !important;
        color: var(--mud-palette-drawer-text) !important;
        display: flex !important;
        align-items: center !important;
        height: auto !important; /* Deixa o padding definir a altura para centralizar melhor */
    }

    .dima-nav .mud-nav-link:hover {
        background: rgba(0, 0, 0, 0.04) !important;
    }

    .dima-nav .mud-nav-link.active {
        background: rgba(0, 180, 216, 0.08) !important;
        color: #00B4D8 !important;
        font-weight: 600 !important;
    }

    /* Indicador lateral sutil para o item ativo */
    .dima-nav .mud-nav-link.active::before {
        content: "";
        position: absolute;
        left: 0;
        height: 60%;
        width: 4px;
        background-color: #00B4D8;
        border-radius: 0 4px 4px 0;
    }

    .dima-nav .mud-nav-link .mud-nav-link-icon-default {
        margin-right: 12px !important;
        font-size: 20px !important;
        color: inherit !important;
        display: flex !important;
        align-items: center !important;
    }
</style>

@code {
    [Parameter]
    public bool IsPremium { get; set; } = false;
}
