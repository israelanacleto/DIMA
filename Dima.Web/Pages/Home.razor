@page "/"
@inherits HomePage

<PageTitle>Dima - Dashboard</PageTitle>

<div class="d-flex justify-space-between align-center mb-8">
    <MudText Typo="Typo.h4">Dashboard</MudText>
    <MudIconButton Icon="@(ShowValues ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                   Color="Color.Inherit"
                   OnClick="ToggleShowValues"
                   Edge="Edge.End"/>
</div>

<MudGrid>
    <MudItem xs="12" sm="6" md="4">
        <MudPaper Elevation="25" Class="pa-4 d-flex flex-column justify-center" Style="height: 150px;">
            <div class="d-flex align-center justify-space-between">
                <MudText Typo="Typo.subtitle1" Class="mud-text-secondary">Entradas</MudText>
                <MudIcon Icon="@Icons.Material.Filled.ArrowCircleUp" Color="Color.Success" Size="Size.Large" />
            </div>
            <div class="mt-auto">
                @if (SummaryLoading)
                {
                    <MudSkeleton Width="80%" Height="48px" />
                }
                else
                {
                    <MudText Typo="Typo.h4">
                        @(ShowValues ? Summary?.Incomes.ToString("C") ?? "R$ 0,00" : "R$ ****")
                    </MudText>
                }
            </div>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" sm="6" md="4">
        <MudPaper Elevation="25" Class="pa-4 d-flex flex-column justify-center" Style="height: 150px;">
            <div class="d-flex align-center justify-space-between">
                <MudText Typo="Typo.subtitle1" Class="mud-text-secondary">Saídas</MudText>
                <MudIcon Icon="@Icons.Material.Filled.ArrowCircleDown" Color="Color.Error" Size="Size.Large" />
            </div>
            <div class="mt-auto">
                @if (SummaryLoading)
                {
                    <MudSkeleton Width="80%" Height="48px" />
                }
                else
                {
                    <MudText Typo="Typo.h4">
                        @(ShowValues ? Summary?.Expenses.ToString("C") ?? "R$ 0,00" : "R$ ****")
                    </MudText>
                }
            </div>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" sm="12" md="4">
        <MudPaper Elevation="25" Class="pa-4 d-flex flex-column justify-center" Style="height: 150px;">
            <div class="d-flex align-center justify-space-between">
                <MudText Typo="Typo.subtitle1" Class="mud-text-secondary">Saldo</MudText>
                <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" Color="Color.Info" Size="Size.Large" />
            </div>
            <div class="mt-auto">
                @if (SummaryLoading)
                {
                    <MudSkeleton Width="80%" Height="48px" />
                }
                else
                {
                    <MudText Typo="Typo.h4" Color="@(Summary is null ? Color.Default : Summary.Total >= 0 ? Color.Success : Color.Error)">
                        @(ShowValues ? Summary?.Total.ToString("C") ?? "R$ 0,00" : "R$ ****")
                    </MudText>
                }
            </div>
        </MudPaper>
    </MudItem>

    <MudItem xs="12">
        <IncomesAndExpensesChart />
    </MudItem>

    <MudItem xs="12" md="6">
        <IncomesByCategoryChart />
    </MudItem>

    <MudItem xs="12" md="6">
        <ExpensesByCategoryChart />
    </MudItem>

    <MudItem xs="12">
        <MostUsedCategoriesChart />
    </MudItem>
</MudGrid>
