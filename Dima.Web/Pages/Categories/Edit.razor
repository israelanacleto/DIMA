@page "/categories/edit/{id}"
@inherits EditCategoryPage

<div class="d-flex flex-column gap-6 animate-fade-in">

    <div class="d-flex align-center justify-space-between">
        <div>
            <MudText Typo="Typo.h3" Style="font-weight: 700; letter-spacing: -0.02em;">Editar Categoria</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-1">
                Atualize as informações da categoria
            </MudText>
        </div>
        <MudButton Variant="Variant.Outlined"
                   StartIcon="@Icons.Material.Outlined.ArrowBack"
                   Color="Color.Secondary"
                   Href="/categories"
                   Disabled="IsBusy"
                   Style="border-radius: 10px; text-transform: none; font-weight: 600;">
            Voltar
        </MudButton>
    </div>

    <MudPaper Elevation="0" Class="form-paper">

        @if (IsBusy && InputModel.Id == 0)
        {
            <div class="d-flex flex-column gap-4">
                <div class="skeleton" style="height: 52px; border-radius: 8px;"></div>
                <div class="skeleton" style="height: 100px; border-radius: 8px;"></div>
                <div class="skeleton" style="height: 48px; border-radius: 10px; margin-top: 0.5rem;"></div>
            </div>
        }
        else
        {
            <EditForm Model="@InputModel" OnValidSubmit="OnValidSubmitAsync">
                <DataAnnotationsValidator/>

                <div class="form-section">
                    <span class="text-label">Informações</span>
                    <MudGrid Spacing="3">
                        <MudItem xs="12">
                            <MudTextField Label="Nome da Categoria"
                                          Placeholder="Ex: Alimentação, Lazer, Saúde"
                                          Variant="Variant.Outlined"
                                          @bind-Value="InputModel.Title"
                                          For="@(() => InputModel.Title)"
                                          Margin="Margin.Dense" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField Label="Descrição"
                                          Lines="3"
                                          Placeholder="Descreva brevemente para que serve esta categoria"
                                          Variant="Variant.Outlined"
                                          @bind-Value="InputModel.Description"
                                          For="@(() => InputModel.Description)"
                                          Margin="Margin.Dense" />
                        </MudItem>
                        <MudItem xs="12">
                            <div class="d-flex align-center justify-space-between mt-2">
                                <MudText Typo="Typo.body1" Style="font-weight: 500;">Categoria Ativa</MudText>
                                <MudSwitch @bind-Value="InputModel.IsActive" 
                                           Color="Color.Primary" 
                                           UnCheckedColor="Color.Error" />
                            </div>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                Categorias inativas não podem ser selecionadas em novos lançamentos.
                            </MudText>
                        </MudItem>
                    </MudGrid>
                </div>

                <MudDivider Class="my-5" />

                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           Size="Size.Large"
                           FullWidth="true"
                           Disabled="IsBusy"
                           Style="border-radius: 10px; font-weight: 600; padding: 14px; text-transform: none;">
                    @if (IsBusy)
                    {
                        <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true"/>
                        <span class="ms-2">Salvando...</span>
                    }
                    else
                    {
                        <span>Salvar Alterações</span>
                    }
                </MudButton>

            </EditForm>
        }

    </MudPaper>

</div>

<style>
    .form-paper {
        border-radius: 14px !important;
        border: 1px solid var(--mud-palette-divider) !important;
        background: var(--mud-palette-surface) !important;
        padding: 2rem;
        max-width: 560px;
    }

    .form-section {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }
</style>
