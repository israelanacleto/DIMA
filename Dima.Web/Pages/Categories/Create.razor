@page "/categories/add"
@using Dima.Web.Components.Categories
@inherits CreateCategoryPage

<div class="d-flex flex-column gap-y-8 animate-fade-in">
    <!-- Cabeçalho -->
    <div class="d-flex align-center justify-space-between">
        <div>
            <MudText Typo="Typo.h4" Style="font-weight: 800;">Nova Categoria</MudText>
            <MudText Typo="Typo.body1" Color="Color.Secondary">Organize suas finanças com categorias personalizadas</MudText>
        </div>
        <MudButton Variant="Variant.Outlined"
                   StartIcon="@Icons.Material.Filled.ArrowBack"
                   Color="Color.Secondary"
                   Href="/categories"
                   Disabled="IsBusy"
                   Style="border-radius: 12px; text-transform: none;">
            Voltar
        </MudButton>
    </div>

    <MudGrid>
        <!-- Formulário principal -->
        <MudItem xs="12" md="7">
            <MudCard Elevation="4" Style="border-radius: 16px;">
                <EditForm Model="@InputModel" OnValidSubmit="OnValidSubmitAsync">
                    <DataAnnotationsValidator/>
                    <MudCardContent Class="pa-8">
                        <div class="d-flex flex-column gap-6">
                            <MudTextField Label="Título"
                                          Placeholder="Ex: Alimentação, Lazer, Saúde"
                                          Variant="Variant.Outlined"
                                          @bind-Value="InputModel.Title"
                                          For="@(() => InputModel.Title)"
                                          Adornment="Adornment.Start"
                                          AdornmentIcon="@Icons.Material.Filled.Title"
                                          AdornmentColor="Color.Primary" />

                            <MudTextField Label="Descrição"
                                          Lines="4"
                                          Placeholder="Descreva brevemente para que serve esta categoria"
                                          Variant="Variant.Outlined"
                                          @bind-Value="InputModel.Description"
                                          For="@(() => InputModel.Description)"
                                          Adornment="Adornment.Start"
                                          AdornmentIcon="@Icons.Material.Filled.Description"
                                          AdornmentColor="Color.Primary" />
                        </div>
                    </MudCardContent>
                    <MudCardActions Class="pa-8 pt-0">
                        <MudButton ButtonType="ButtonType.Submit"
                                   Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   Size="Size.Large"
                                   FullWidth="true"
                                   Disabled="IsBusy"
                                   Style="border-radius: 12px; font-weight: 600; padding: 16px; text-transform: none;">
                            @if (IsBusy)
                            {
                                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true"/>
                                <span class="ms-2">Salvando...</span>
                            }
                            else
                            {
                                <span>Criar Categoria</span>
                            }
                        </MudButton>
                    </MudCardActions>
                </EditForm>
            </MudCard>
        </MudItem>

        <!-- Sidebar de Informações -->
        <CategoryHelperSidebar />
    </MudGrid>
</div>

<style>
    .animate-fade-in {
        animation: fadeIn 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>