@page "/orders"
@using Dima.Core.Enums
@using Dima.Core.Models
@inherits ListOrdersPage

<div class="d-flex flex-column gap-6 animate-fade-in">

    @* Header *@
    <div class="d-flex align-center justify-space-between flex-wrap gap-3">
        <div>
            <MudText Typo="Typo.h3" Style="font-weight: 700; letter-spacing: -0.02em;">
                @(IsPremium ? "Meus Planos" : "Meus Pedidos")
            </MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-1">
                Gerencie suas assinaturas e histórico de compras
            </MudText>
        </div>
        <MudButton
            Variant="Variant.Filled"
            Color="Color.Primary"
            StartIcon="@Icons.Material.Outlined.WorkspacePremium"
            Href="/plans"
            Class="dima-action-btn">
            Ver Planos
        </MudButton>
    </div>

    @* Tabela *@
    <MudTable Items="@Orders"
              T="Order"
              Hover="true"
              Elevation="0"
              Loading="@IsBusy"
              RowsPerPage="10"
              Class="dima-table">
        <ToolBarContent>
            <MudText Typo="Typo.h6" Style="font-weight: 600;">Histórico de Pedidos</MudText>
            <MudSpacer/>
        </ToolBarContent>
        <HeaderContent>
            <MudTh>Pedido</MudTh>
            <MudTh>Plano</MudTh>
            <MudTh>Data</MudTh>
            <MudTh>Vencimento</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Total</MudTh>
            <MudTh Style="text-align: right">Ações</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Pedido">
                <span class="text-mono" style="font-size: 0.8125rem; color: var(--mud-palette-text-secondary);">
                    #@context.Number
                </span>
            </MudTd>
            <MudTd DataLabel="Plano">
                <MudText Typo="Typo.body2" Style="font-weight: 600;">@context.Product.Title</MudText>
            </MudTd>
            <MudTd DataLabel="Data">
                <MudText Typo="Typo.body2">@context.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy")</MudText>
            </MudTd>
            <MudTd DataLabel="Vencimento">
                <MudText Typo="Typo.body2">
                    @(context.SubscriptionEndDate?.ToLocalTime().ToString("dd/MM/yyyy") ?? "—")
                </MudText>
            </MudTd>
            <MudTd DataLabel="Status">
                @switch (context.Status)
                {
                    case EOrderStatus.WaitingPayment:
                        <span class="badge-warning">⏳ Aguardando</span>
                        break;
                    case EOrderStatus.Paid:
                        @if (context.SubscriptionEndDate >= DateTime.UtcNow)
                        {
                            <span class="badge-success">✓ Ativo</span>
                        }
                        else
                        {
                            <span class="badge-warning">⚠ Vencido</span>
                        }
                        break;
                    case EOrderStatus.Canceled:
                        <span class="badge-danger">✕ Cancelado</span>
                        break;
                    case EOrderStatus.Refunded:
                        <span class="badge-info">↩ Estornado</span>
                        break;
                }
            </MudTd>
            <MudTd DataLabel="Total">
                <span class="text-financial" style="font-size: 0.9rem;">
                    @context.Total.ToString("C")
                </span>
            </MudTd>
            <MudTd DataLabel="Ações" Style="text-align: right">
                <MudTooltip Text="Ver detalhes">
                    <MudIconButton
                        Icon="@Icons.Material.Outlined.Visibility"
                        Href="@($"/orders/{context.Number}")"
                        Color="Color.Primary"
                        Size="Size.Small"
                        Variant="Variant.Text"/>
                </MudTooltip>
            </MudTd>
        </RowTemplate>
        <NoRecordsContent>
            <div class="empty-state">
                <div class="empty-icon-wrap">
                    <MudIcon Icon="@Icons.Material.Outlined.ReceiptLong" Style="font-size: 36px; color: #64748B;" />
                </div>
                <MudText Typo="Typo.h6" Style="font-weight: 600; color: #64748B;">
                    Nenhum pedido ainda
                </MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Conheça os planos disponíveis e escolha o que melhor se adapta a você.
                </MudText>
                <MudButton
                    Variant="Variant.Filled"
                    Color="Color.Primary"
                    StartIcon="@Icons.Material.Outlined.WorkspacePremium"
                    Href="/plans"
                    Class="dima-action-btn mt-2">
                    Ver Planos Disponíveis
                </MudButton>
            </div>
        </NoRecordsContent>
        <PagerContent>
            <MudTablePager
                RowsPerPageString="Itens por página:"
                InfoFormat="{first_item}-{last_item} de {all_items}"
                HorizontalAlignment="HorizontalAlignment.Right" />
        </PagerContent>
    </MudTable>
</div>

<style>
    .dima-action-btn {
        border-radius: 10px !important;
        text-transform: none !important;
        font-weight: 600 !important;
    }

    .dima-table {
        border-radius: 14px !important;
        border: 1px solid var(--mud-palette-divider) !important;
        background: var(--mud-palette-surface) !important;
        overflow: hidden;
    }

    .empty-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.625rem;
        padding: 3.5rem 1.5rem;
        text-align: center;
    }

    .empty-icon-wrap {
        width: 72px;
        height: 72px;
        border-radius: 50%;
        background: rgba(100, 116, 139, 0.08);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 0.5rem;
    }
</style>
