@page "/orders/{OrderNumber}/success"
@inherits SuccessPage

<MudText Typo="Typo.h4" Style="font-weight: 800;">Pedido @OrderNumber</MudText>
<MudText Typo="Typo.body1" Color="Color.Secondary">
    @(IsConfirmed ? "Pagamento realizado com sucesso!" : "Aguardando confirmação do pagamento...")
</MudText>

<MudGrid Class="mt-8 animate-fade-in">
    <MudItem xs="12">
        <MudCard Elevation="4" Style="border-radius: 16px;">
            <MudCardContent Class="d-flex flex-column align-center py-12">
                @if (IsBusy && !IsConfirmed)
                {
                    <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
                    <MudText Typo="Typo.h5" Class="mt-4" Color="Color.Primary" Style="font-weight: 700;">Confirmando...</MudText>
                    <MudText Typo="Typo.body1" Color="Color.Secondary" Align="Align.Center" Class="mt-2">
                        Estamos confirmando seu pagamento com o Stripe, por favor aguarde um momento.
                    </MudText>
                }
                else if (IsConfirmed)
                {
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Style="font-size: 96px;"/>
                    <MudText Typo="Typo.h5" Class="mt-4" Color="Color.Success" Style="font-weight: 700;">Tudo certo!</MudText>
                    <MudText Typo="Typo.body1" Color="Color.Secondary" Align="Align.Center" Class="mt-2">
                        Recebemos o seu pagamento e sua assinatura já está ativa.
                    </MudText>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Class="mt-8"
                               Href="@($"/orders/{OrderNumber}")"
                               Style="border-radius: 8px; text-transform: none;">
                        Ver Detalhes do Pedido
                    </MudButton>
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Filled.Error" Color="Color.Error" Style="font-size: 96px;"/>
                    <MudText Typo="Typo.h5" Class="mt-4" Color="Color.Error" Style="font-weight: 700;">Ops!</MudText>
                    <MudText Typo="Typo.body1" Color="Color.Secondary" Align="Align.Center" Class="mt-2">
                        Não conseguimos confirmar seu pagamento automaticamente. <br/>
                        Ele pode levar alguns minutos para ser processado pelo Stripe.
                    </MudText>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Class="mt-8"
                               OnClick="ConfirmPaymentAsync"
                               Disabled="IsBusy"
                               Style="border-radius: 8px; text-transform: none;">
                        Tentar Novamente
                    </MudButton>
                    <MudButton Variant="Variant.Text"
                               Color="Color.Secondary"
                               Class="mt-2"
                               Href="@($"/orders/{OrderNumber}")"
                               Style="border-radius: 8px; text-transform: none;">
                        Ver Detalhes do Pedido
                    </MudButton>
                }
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

<style>
    .animate-fade-in {
        animation: fadeIn 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>
