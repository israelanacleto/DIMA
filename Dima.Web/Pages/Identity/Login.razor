@page "/login"
@layout HeadlessLayout

<PageTitle>Dima - Entrar</PageTitle>

<MudGrid Justify="Justify.Center">
    <MudItem xs="12" sm="12" md="8" lg="6" xl="6" xxl="6">
        <MudPaper Class="mud-width-full pa-8">
            <div class="d-flex justify-center pb-8 pt-8">
                <img
                    src="img/dima.png"
                    alt="Dima - Controle Financeiro"
                    width="200"/>
            </div>
            
            <MudForm @ref="_mudForm">
                <MudTextField
                    T="string"
                    Label="E-mail"
                    HelperText="Campo obrigatório"
                    InputType="InputType.Email"/>

                <MudTextField
                    T="string"
                    Label="Senha"
                    HelperText="Campo obrigatório"
                    InputType="InputType.Password"/>
            </MudForm>
            
            <div class="d-flex flex-column mt-8 gap-2">
                <MudButton
                    Variant="Variant.Filled"
                    FullWidth="true"
                    Color="Color.Primary">
                    Entrar
                </MudButton>
                <MudButton
                    Variant="Variant.Text"
                    FullWidth="true"
                    Href="/register">
                    Não possui uma conta?
                </MudButton>
            </div>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {

    MudForm? _mudForm;

}