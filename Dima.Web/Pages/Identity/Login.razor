@page "/login"
@layout HeadlessLayout
@inherits LoginPage

<PageTitle>Dima — Entrar</PageTitle>

<div class="auth-form-wrap">
    <div class="auth-form-header">
        <MudText Typo="Typo.h4" Style="font-weight: 700; letter-spacing: -0.02em;">
            Bem-vindo de volta
        </MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-1">
            Entre na sua conta para continuar
        </MudText>
    </div>

    <EditForm Model="@InputModel" OnValidSubmit="OnValidSubmitAsync" class="auth-form-fields">
        <DataAnnotationsValidator />

        <MudTextField
            T="string"
            Label="E-mail"
            Variant="Variant.Outlined"
            InputType="InputType.Email"
            For="@(() => InputModel.Email)"
            @bind-Value="InputModel.Email"
            Margin="Margin.Dense"
            Class="auth-field"/>

        <MudTextField
            T="string"
            Label="Senha"
            Variant="Variant.Outlined"
            InputType="InputType.Password"
            For="@(() => InputModel.Password)"
            @bind-Value="InputModel.Password"
            Margin="Margin.Dense"
            Class="auth-field"/>

        <div class="auth-actions">
            @if (IsBusy)
            {
                <div class="d-flex justify-center py-2">
                    <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Small"/>
                </div>
            }
            else
            {
                <MudButton
                    ButtonType="ButtonType.Submit"
                    Variant="Variant.Filled"
                    FullWidth="true"
                    Color="Color.Primary"
                    Size="Size.Large"
                    Class="auth-submit-btn">
                    Entrar
                </MudButton>
            }
        </div>
    </EditForm>

    <MudDivider Class="my-4" />

    <div class="auth-footer-links">
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            Não possui uma conta?
            <MudLink Href="/register" Color="Color.Secondary" Style="font-weight: 700;">
                Cadastre-se
            </MudLink>
        </MudText>
        <MudLink Href="/help" Typo="Typo.body2" Color="Color.Secondary" Class="mt-2">
            Como funciona o DIMA?
        </MudLink>
    </div>
</div>

<style>
    .auth-form-wrap {
        display: flex;
        flex-direction: column;
        gap: 0;
        width: 100%;
    }

    .auth-form-header {
        margin-bottom: 2rem;
    }

    .auth-form-fields {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .auth-field {
        width: 100%;
    }

    .auth-actions {
        margin-top: 0.5rem;
    }

    .auth-submit-btn {
        border-radius: 10px !important;
        font-weight: 600 !important;
        padding: 12px 0 !important;
        letter-spacing: 0.01em !important;
        text-transform: none !important;
    }

    .auth-footer-links {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        text-align: center;
    }
</style>
