@page "/register"
@layout HeadlessLayout
@inherits RegisterPage

<PageTitle>Dima — Criar Conta</PageTitle>

<div class="auth-form-wrap">
    <div class="auth-form-header">
        <MudText Typo="Typo.h4" Style="font-weight: 700; letter-spacing: -0.02em;">
            Crie sua conta
        </MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-1">
            Grátis para sempre. Sem cartão de crédito.
        </MudText>
    </div>

    <EditForm Model="@InputModel" OnValidSubmit="OnValidSubmitAsync" class="auth-form-fields">
        <DataAnnotationsValidator />

        <MudTextField
            T="string"
            Label="E-mail"
            Variant="Variant.Outlined"
            InputType="InputType.Email"
            For="@(() => InputModel.Email)"
            @bind-Value="InputModel.Email"
            Margin="Margin.Dense"
            Class="auth-field"/>

        <MudTextField
            T="string"
            Label="Senha"
            Variant="Variant.Outlined"
            InputType="InputType.Password"
            For="@(() => InputModel.Password)"
            @bind-Value="InputModel.Password"
            Margin="Margin.Dense"
            Class="auth-field"/>

        <div class="auth-demo-check">
            <MudCheckBox
                @bind-Value="InputModel.GenerateDemoData"
                Color="Color.Primary"
                Dense="true">
                <ChildContent>
                    <MudText Typo="Typo.body2">
                        Gerar dados de demonstração
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Style="display: block;">
                            Cria categorias e transações de exemplo para explorar a plataforma
                        </MudText>
                    </MudText>
                </ChildContent>
            </MudCheckBox>
        </div>

        <div class="auth-actions">
            @if (IsBusy)
            {
                <div class="d-flex justify-center py-2">
                    <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Small"/>
                </div>
            }
            else
            {
                <MudButton
                    ButtonType="ButtonType.Submit"
                    Variant="Variant.Filled"
                    FullWidth="true"
                    Color="Color.Primary"
                    Size="Size.Large"
                    Class="auth-submit-btn">
                    Criar Conta Gratuita
                </MudButton>
            }
        </div>
    </EditForm>

    <MudDivider Class="my-4" />

    <div class="auth-footer-links">
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            Já tem uma conta?
            <MudLink Href="/login" Color="Color.Secondary" Style="font-weight: 700;">
                Entre aqui
            </MudLink>
        </MudText>
    </div>
</div>

<style>
    .auth-form-wrap {
        display: flex;
        flex-direction: column;
        gap: 0;
        width: 100%;
    }

    .auth-form-header {
        margin-bottom: 2rem;
    }

    .auth-form-fields {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .auth-field {
        width: 100%;
    }

    .auth-demo-check {
        padding: 0.875rem;
        background: var(--mud-palette-overlay-light);
        border-radius: 10px;
        border: 1px solid var(--mud-palette-divider);
    }

    .auth-actions {
        margin-top: 0.5rem;
    }

    .auth-submit-btn {
        border-radius: 10px !important;
        font-weight: 600 !important;
        padding: 12px 0 !important;
        letter-spacing: 0.01em !important;
        text-transform: none !important;
    }

    .auth-footer-links {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
    }
</style>
