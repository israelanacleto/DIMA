@page "/help"
@using Microsoft.AspNetCore.Authorization
@attribute [AllowAnonymous]

<PageTitle>Dima - Ajuda & Documentação</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8 animate-fade-in">
    <div class="d-flex align-center mb-8">
        <MudIcon Icon="@Icons.Material.Filled.HelpCenter" Color="Color.Primary" Size="Size.Large" Class="mr-4" />
        <div>
            <MudText Typo="Typo.h4" Style="font-weight: 800;">Central de Ajuda</MudText>
            <MudText Typo="Typo.body1" Color="Color.Secondary">Entenda como extrair o máximo do ecossistema DIMA</MudText>
        </div>
    </div>

    <MudTabs Elevation="4" Rounded="true" ApplyEffectsToContents="true" PanelClass="pa-6" Color="Color.Primary">
        <MudTabPanel Icon="@Icons.Material.Filled.RocketLaunch" Text="Primeiros Passos">
            <MudText Typo="Typo.h6" Class="mb-4">Seja bem-vindo ao DIMA!</MudText>
            <MudText Typo="Typo.body1" Class="mb-4">
                O DIMA é mais que um gerenciador financeiro; é uma ferramenta de decisão. O processo começa com a criação da sua conta. 
                Ao se registrar, recomendamos ativar o <b>Smart Seeding</b> para que você já comece com uma base de dados pronta para exploração.
            </MudText>
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-4">
                Dica: O Dashboard consolidado é o seu centro de comando. Verifique-o diariamente para entender sua saúde financeira.
            </MudAlert>
        </MudTabPanel>

        <MudTabPanel Icon="@Icons.Material.Filled.Category" Text="Categorias">
            <MudText Typo="Typo.h6" Class="mb-4">Organizando seus Baldes</MudText>
            <MudText Typo="Typo.body1" Class="mb-4">
                Antes de registrar gastos, você precisa definir suas <b>Categorias</b>. Elas permitem que o sistema agrupe seus dados 
                e gere gráficos inteligentes.
            </MudText>
            <MudExpansionPanels MultiExpansion="true" Class="mt-4">
                <MudExpansionPanel Text="Como criar uma categoria?">
                    Navegue até o menu 'Categorias', clique no botão de adicionar e informe um título e uma descrição breve. 
                    Exemplo: 'Educação', 'Streaming', 'Manutenção Casa'.
                </MudExpansionPanel>
                <MudExpansionPanel Text="Posso excluir categorias?">
                    Sim, desde que não existam lançamentos vinculados a elas. Isso garante a integridade dos seus relatórios.
                </MudExpansionPanel>
            </MudExpansionPanels>
        </MudTabPanel>

        <MudTabPanel Icon="@Icons.Material.Filled.SwapVerticalCircle" Text="Lançamentos">
            <MudText Typo="Typo.h6" Class="mb-4">Registrando o Fluxo</MudText>
            <MudText Typo="Typo.body1" Class="mb-4">
                Os lançamentos são os registros individuais de cada movimentação financeira.
            </MudText>
            <MudGrid Class="mt-2">
                <MudItem xs="12" md="6">
                    <MudPaper Class="pa-4 mud-background-gray" Elevation="0">
                        <MudText Typo="Typo.subtitle1" Color="Color.Success" Style="font-weight: 700;">Entradas (Deposits)</MudText>
                        <MudText Typo="Typo.body2">Salário, dividendos, rendas extras ou transferências recebidas.</MudText>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12" md="6">
                    <MudPaper Class="pa-4 mud-background-gray" Elevation="0">
                        <MudText Typo="Typo.subtitle1" Color="Color.Error" Style="font-weight: 700;">Saídas (Withdrawals)</MudText>
                        <MudText Typo="Typo.body2">Contas fixas, lazer, alimentação e qualquer saída de capital.</MudText>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        <MudTabPanel Icon="@Icons.Material.Filled.Star" Text="Elite Premium">
            <MudText Typo="Typo.h6" Class="mb-4">Experiência Elite</MudText>
            <MudText Typo="Typo.body1" Class="mb-4">
                Usuários Premium têm acesso a planos exclusivos e gestão avançada de assinaturas.
            </MudText>
            <MudTimeline TimelinePosition="TimelinePosition.Left" Class="mt-4">
                <MudTimelineItem Color="Color.Primary" Variant="Variant.Filled">
                    <ItemContent>
                        <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">Escolha do Plano</MudText>
                        <MudText Typo="Typo.body2">Navegue pelas opções na aba 'Planos'.</MudText>
                    </ItemContent>
                </MudTimelineItem>
                <MudTimelineItem Color="Color.Secondary" Variant="Variant.Filled">
                    <ItemContent>
                        <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">Checkout Seguro</MudText>
                        <MudText Typo="Typo.body2">Pagamento processado via integração oficial com Stripe.</MudText>
                    </ItemContent>
                </MudTimelineItem>
                <MudTimelineItem Color="Color.Info" Variant="Variant.Filled">
                    <ItemContent>
                        <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">Status do Pedido</MudText>
                        <MudText Typo="Typo.body2">Acompanhe seu histórico e validade da assinatura em 'Meus Pedidos'.</MudText>
                    </ItemContent>
                </MudTimelineItem>
            </MudTimeline>
        </MudTabPanel>
    </MudTabs>

    <div class="d-flex justify-center mt-12 pb-12">
        <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.ArrowBack" Href="/">
            Voltar ao Dashboard
        </MudButton>
    </div>
</MudContainer>

<style>
    .mud-tab-slider {
        height: 4px !important;
        border-radius: 4px 4px 0 0;
    }
</style>
