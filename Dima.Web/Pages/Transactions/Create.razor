@page "/transactions/add"
@inherits CreateTransactionPage

<div class="d-flex flex-column gap-6 animate-fade-in">

    <div class="d-flex align-center justify-space-between">
        <div>
            <MudText Typo="Typo.h3" Style="font-weight: 700; letter-spacing: -0.02em;">Novo Lançamento</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-1">
                Registre uma entrada ou saída financeira
            </MudText>
        </div>
        <MudButton Variant="Variant.Outlined"
                   StartIcon="@Icons.Material.Outlined.ArrowBack"
                   Color="Color.Secondary"
                   Href="/transactions"
                   Disabled="IsBusy"
                   Style="border-radius: 10px; text-transform: none; font-weight: 600;">
            Voltar
        </MudButton>
    </div>

    <MudPaper Elevation="0" Class="form-paper">
        <EditForm Model="@InputModel" OnValidSubmit="OnValidSubmitAsync">
            <DataAnnotationsValidator/>

            <div class="form-section">
                <span class="text-label">Identificação</span>
                <MudGrid Spacing="3">
                    <MudItem xs="12">
                        <MudTextField Label="Título"
                                      Placeholder="Ex: Salário, Aluguel, Supermercado"
                                      Variant="Variant.Outlined"
                                      @bind-Value="InputModel.Title"
                                      For="@(() => InputModel.Title)"
                                      Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudNumericField Label="Valor"
                                         T="decimal"
                                         Format="C"
                                         HideSpinButtons="true"
                                         Variant="Variant.Outlined"
                                         @bind-Value="InputModel.Amount"
                                         For="@(() => InputModel.Amount)"
                                         Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudDatePicker Label="Data"
                                       Variant="Variant.Outlined"
                                       @bind-Date="@InputModel.PaidOrReceivedAt"
                                       For="@(() => InputModel.PaidOrReceivedAt)"
                                       Margin="Margin.Dense"
                                       HelperText="Data do pagamento ou recebimento" />
                    </MudItem>
                </MudGrid>
            </div>

            <MudDivider Class="my-5" />

            <div class="form-section">
                <span class="text-label">Classificação</span>
                <MudGrid Spacing="3">
                    <MudItem xs="12">
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-2">
                            Tipo de movimentação
                        </MudText>
                        <MudToggleGroup T="ETransactionType"
                                        @bind-Value="InputModel.Type"
                                        SelectionMode="SelectionMode.SingleSelection"
                                        Color="Color.Primary"
                                        CheckMark="false"
                                        Delimiters="false"
                                        Class="mud-width-full"
                                        Style="background-color: var(--mud-palette-background-gray); border-radius: 10px; padding: 4px;">
                            <MudToggleItem Value="ETransactionType.Deposit"
                                           UnselectedIcon="@Icons.Material.Outlined.TrendingUp"
                                           SelectedIcon="@Icons.Material.Filled.TrendingUp"
                                           Text="Entrada" />
                            <MudToggleItem Value="ETransactionType.Withdrawal"
                                           UnselectedIcon="@Icons.Material.Outlined.TrendingDown"
                                           SelectedIcon="@Icons.Material.Filled.TrendingDown"
                                           Text="Saída" />
                        </MudToggleGroup>
                    </MudItem>
                    <MudItem xs="12">
                        <MudSelect T="long"
                                   Label="Categoria"
                                   Variant="Variant.Outlined"
                                   @bind-Value="InputModel.CategoryId"
                                   Margin="Margin.Dense">
                            @foreach (var item in CategoriesCombo)
                            {
                                <MudSelectItem T="long" Value="@long.Parse(item.Value)">
                                    @item.Label
                                </MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                </MudGrid>
            </div>

            <MudDivider Class="my-5" />

            <div class="form-actions">
                <MudButton ButtonType="ButtonType.Submit"
                           Variant="Variant.Filled"
                           Color="Color.Primary"
                           Size="Size.Large"
                           FullWidth="true"
                           Disabled="IsBusy"
                           Style="border-radius: 10px; font-weight: 600; padding: 14px; text-transform: none;">
                    @if (IsBusy)
                    {
                        <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true"/>
                        <span class="ms-2">Salvando...</span>
                    }
                    else
                    {
                        <span>Criar Lançamento</span>
                    }
                </MudButton>
            </div>

        </EditForm>
    </MudPaper>

</div>

<style>
    .form-paper {
        border-radius: 14px !important;
        border: 1px solid var(--mud-palette-divider) !important;
        background: var(--mud-palette-surface) !important;
        padding: 2rem;
        max-width: 640px;
    }

    .form-section {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .form-actions {
        max-width: 100%;
    }
</style>
