@page "/transactions/history"
@using Dima.Core.Models
@inherits ListTransactionsPage

<div class="d-flex flex-column gap-y-8 animate-fade-in">

    <!-- Cabeçalho -->
    <div class="d-flex align-center justify-space-between">
        <div>
            <MudText Typo="Typo.h4" Style="font-weight: 800;">Lançamentos</MudText>
            <MudText Typo="Typo.body1" Color="Color.Secondary">Visualize e gerencie seu histórico financeiro</MudText>
        </div>
        <MudButton
            Variant="Variant.Filled"
            Color="Color.Primary"
            StartIcon="@Icons.Material.Filled.Add"
            Href="/transactions/add"
            Style="border-radius: 12px; text-transform: none;">
            Novo Lançamento
        </MudButton>
    </div>

    <!-- Filtros de Período -->
    <MudCard Elevation="4" Style="border-radius: 16px;">
        <MudCardContent Class="d-flex align-center gap-4 pa-4">
            <MudSelect T="int"
                       Label="Mês"
                       @bind-Value="CurrentMonth"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       AnchorOrigin="Origin.BottomCenter"
                       Style="min-width: 150px;">
                @for (var month = 1; month <= 12; month++)
                {
                    var date = new DateTime(DateTime.Now.Year, month, 1);
                    <MudSelectItem T="int" Value="@month">
                        @(date.ToString("MMMM"))
                    </MudSelectItem>
                }
            </MudSelect>
            <MudSelect T="int"
                       Label="Ano"
                       @bind-Value="@CurrentYear"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       AnchorOrigin="Origin.BottomCenter"
                       Style="min-width: 120px;">
                @foreach (var year in Years)
                {
                    <MudSelectItem T="int" Value="@year">
                        @year
                    </MudSelectItem>
                }
            </MudSelect>
            <MudSpacer/>
            <MudButton
                Variant="Variant.Filled"
                Color="Color.Secondary"
                StartIcon="@Icons.Material.Filled.Search"
                OnClick="OnSearchAsync"
                Style="border-radius: 8px; height: 40px; text-transform: none;">
                Pesquisar
            </MudButton>
        </MudCardContent>
    </MudCard>

    <MudTable Items="@Transactions"
              T="Transaction"
              Filter="Filter"
              Hover="true"
              Elevation="4"
              Loading="@IsBusy"
              RowsPerPage="10"
              Style="border-radius: 16px;"
              Class="pa-4">
        <ToolBarContent>
            <MudText Typo="Typo.h6">Histórico</MudText>
            <MudSpacer/>
            <MudTextField
                @bind-Value="SearchTerm"
                Placeholder="Filtrar por título ou ID..."
                Adornment="Adornment.Start"
                AdornmentIcon="@Icons.Material.Filled.Search"
                Immediate="true"
                IconSize="Size.Medium"
                Class="mt-0">
            </MudTextField>
        </ToolBarContent>
        <HeaderContent>
            <MudTh>
                <MudTableSortLabel SortBy="new Func<Transaction, object>(x => x.Title)">
                    Lançamento
                </MudTableSortLabel>
            </MudTh>
            <MudTh>Tipo</MudTh>
            <MudTh>
                <MudTableSortLabel SortBy="new Func<Transaction, object>(x => x.Amount)">
                    Valor
                </MudTableSortLabel>
            </MudTh>
            <MudTh Style="text-align: right">Ações</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Lançamento">
                <MudText Typo="Typo.body1" Style="font-weight: 600;">@context.Title</MudText>
            </MudTd>
            <MudTd DataLabel="Tipo">
                @if (context.Type == ETransactionType.Deposit)
                {
                    <MudChip Color="Color.Success" Size="Size.Small" Variant="Variant.Filled" T="string">
                        entrada
                    </MudChip>
                }
                else
                {
                    <MudChip Color="Color.Error" Size="Size.Small" Variant="Variant.Filled" T="string">
                        saída
                    </MudChip>
                }
            </MudTd>
            <MudTd DataLabel="Valor">
                <MudText Typo="Typo.body1" Color="@(context.Type == ETransactionType.Deposit ? Color.Success : Color.Error)" Style="font-weight: 700;">
                    @context.Amount.ToString("C")
                </MudText>
            </MudTd>
            <MudTd DataLabel="Ações" Style="text-align: right">
                <MudStack Row Justify="Justify.FlexEnd" Spacing="0">
                    <MudTooltip Text="Editar">
                        <MudIconButton 
                            Icon="@Icons.Material.Filled.Edit"
                            Href="@($"/transactions/edit/{context.Id}")"
                            Color="Color.Primary"
                            Size="Size.Small"
                            Variant="Variant.Text">
                        </MudIconButton>
                    </MudTooltip>
                    <MudTooltip Text="Excluir">
                        <MudIconButton 
                            Icon="@Icons.Material.Filled.Delete"
                            Color="Color.Error"
                            Size="Size.Small"
                            Variant="Variant.Text"
                            OnClick="() => OnDeleteButtonClickedAsync(context.Id, context.Title)">
                        </MudIconButton>
                    </MudTooltip>
                </MudStack>
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager 
                RowsPerPageString="Itens por página:"
                InfoFormat="{first_item}-{last_item} de {all_items}"
                HorizontalAlignment="HorizontalAlignment.Right" />
        </PagerContent>
    </MudTable>
</div>

<style>
    .animate-fade-in {
        animation: fadeIn 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>