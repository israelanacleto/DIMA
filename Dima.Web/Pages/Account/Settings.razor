@page "/settings"
@using Dima.Web.Components.Identity
@inherits SettingsPage

<div class="d-flex flex-column gap-y-8 animate-fade-in">
    <!-- Cabeçalho -->
    <div class="d-flex align-center justify-space-between">
        <div>
            <MudText Typo="Typo.h4" Style="font-weight: 800;">Configurações</MudText>
            <MudText Typo="Typo.body1" Color="Color.Secondary">Gerencie as preferências da aplicação e sua assinatura</MudText>
        </div>
        <MudButton Variant="Variant.Outlined"
                   StartIcon="@Icons.Material.Filled.ArrowBack"
                   Color="Color.Secondary"
                   Href="/"
                   Disabled="IsBusy"
                   Style="border-radius: 12px; text-transform: none;">
            Voltar
        </MudButton>
    </div>

    @if (IsBusy)
    {
        <MudGrid>
            <MudItem xs="12" md="8">
                <MudCard Elevation="4" Style="border-radius: 16px;">
                    <MudCardContent Class="pa-8">
                        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="400px" />
                    </MudCardContent>
                </MudCard>
            </MudItem>
            <SettingsHelperSidebar />
        </MudGrid>
    }
    else
    {
        <MudGrid>
            <MudItem xs="12" md="8">
                <MudCard Elevation="4" Style="border-radius: 16px; overflow: hidden;">
                    <MudTabs Elevation="0"
                             Rounded="true"
                             SliderColor="Color.Primary"
                             ApplyEffectsToContents="true"
                             PanelClass="pa-8">

                        <MudTabPanel Text="Preferências" Icon="@Icons.Material.Filled.Tune">
                            <MudGrid>
                                <MudItem xs="12">
                                    <MudText Typo="Typo.h6" Style="font-weight: 700;">Aparência e Comportamento</MudText>
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">Em breve você poderá personalizar o visual da sua plataforma.</MudText>
                                </MudItem>
                                
                                <MudItem xs="12">
                                    <MudDivider Class="my-4" />
                                </MudItem>

                                <MudItem xs="12" md="6">
                                    <MudSelect T="string" Label="Tema" Variant="Variant.Outlined" Disabled="true" AdornmentIcon="@Icons.Material.Filled.Palette" AdornmentColor="Color.Primary">
                                        <MudSelectItem Value="@("Escuro")">Escuro</MudSelectItem>
                                        <MudSelectItem Value="@("Claro")">Claro</MudSelectItem>
                                    </MudSelect>
                                </MudItem>

                                <MudItem xs="12" md="6">
                                    <MudSelect T="string" Label="Idioma" Variant="Variant.Outlined" Disabled="true" AdornmentIcon="@Icons.Material.Filled.Language" AdornmentColor="Color.Primary">
                                        <MudSelectItem Value="@("Português (Brasil)")">Português (Brasil)</MudSelectItem>
                                        <MudSelectItem Value="@("English")">English</MudSelectItem>
                                    </MudSelect>
                                </MudItem>

                                <MudItem xs="12" Class="mt-4">
                                    <MudButton Variant="Variant.Filled"
                                               Color="Color.Primary"
                                               Size="Size.Large"
                                               FullWidth="true"
                                               Disabled="true"
                                               Style="border-radius: 12px; font-weight: 600; padding: 16px; text-transform: none;">
                                        Salvar Preferências
                                    </MudButton>
                                </MudItem>
                            </MudGrid>
                        </MudTabPanel>

                        <MudTabPanel Text="Plano e Assinatura" Icon="@Icons.Material.Filled.Star">
                            <MudGrid>
                                <MudItem xs="12">
                                    <MudText Typo="Typo.h6" Style="font-weight: 700;">Gestão de Assinatura</MudText>
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">Visualize seu plano atual e gerencie seus pagamentos.</MudText>
                                </MudItem>

                                <MudItem xs="12">
                                    <MudDivider Class="my-4" />
                                </MudItem>

                                @if (Order is not null)
                                {
                                    <MudItem xs="12">
                                        <MudCard Elevation="0" Outlined="true" Style="border-radius: 16px;">
                                            <MudCardContent Class="pa-6">
                                                <div class="d-flex align-center gap-4">
                                                    <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Large">
                                                        <MudIcon Icon="@Icons.Material.Filled.Star" />
                                                    </MudAvatar>
                                                    <div>
                                                        <MudText Typo="Typo.h6" Style="font-weight: 700;">@Order.Product.Title</MudText>
                                                        <MudText Typo="Typo.body2" Color="Color.Secondary">Sua assinatura está ativa e sendo renovada automaticamente.</MudText>
                                                        
                                                        <MudList T="string" Class="mt-4" Dense="true">
                                                            @foreach (var benefit in Order.Product.Benefits)
                                                            {
                                                                <MudListItem Icon="@Icons.Material.Filled.CheckCircle" IconColor="Color.Success">
                                                                    <MudText Typo="Typo.body2">@benefit</MudText>
                                                                </MudListItem>
                                                            }
                                                        </MudList>
                                                    </div>
                                                    <MudSpacer />
                                                    <MudChip Color="Color.Success" Variant="Variant.Filled" Size="Size.Small" T="string">ATIVO</MudChip>
                                                </div>

                                                <MudGrid Class="mt-6">
                                                    <MudItem xs="6" sm="3">
                                                        <MudText Typo="Typo.caption" Color="Color.Secondary">PEDIDO</MudText>
                                                        <MudText Typo="Typo.body1" Style="font-weight: 600;">#@Order.Number</MudText>
                                                    </MudItem>
                                                    <MudItem xs="6" sm="3">
                                                        <MudText Typo="Typo.caption" Color="Color.Secondary">VALOR</MudText>
                                                        <MudText Typo="Typo.body1" Style="font-weight: 600;">@Order.Total.ToString("C")</MudText>
                                                    </MudItem>
                                                    <MudItem xs="6" sm="3">
                                                        <MudText Typo="Typo.caption" Color="Color.Secondary">DATA</MudText>
                                                        <MudText Typo="Typo.body1" Style="font-weight: 600;">@Order.CreatedAt.ToString("dd/MM/yyyy")</MudText>
                                                    </MudItem>
                                                    <MudItem xs="6" sm="3" Class="d-flex align-center justify-end">
                                                        <MudButton Variant="Variant.Outlined"
                                                                   Color="Color.Error"
                                                                   Size="Size.Small"
                                                                   Disabled="true"
                                                                   Style="border-radius: 8px; text-transform: none;">
                                                            Cancelar
                                                        </MudButton>
                                                    </MudItem>
                                                </MudGrid>
                                            </MudCardContent>
                                        </MudCard>
                                    </MudItem>
                                }
                                else
                                {
                                    <MudItem xs="12">
                                        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mt-2" Style="border-radius: 12px;">
                                            Você ainda não possui uma assinatura premium ativa.
                                        </MudAlert>
                                    </MudItem>
                                }

                                <MudItem xs="12" Class="mt-4">
                                    <MudButton Variant="Variant.Filled"
                                               Color="Color.Primary"
                                               Size="Size.Large"
                                               FullWidth="true"
                                               Href="/plans"
                                               Style="border-radius: 12px; font-weight: 600; padding: 16px; text-transform: none;">
                                        Ver Planos Disponíveis
                                    </MudButton>
                                </MudItem>
                                
                                <MudItem xs="12">
                                    <MudAlert Severity="Severity.Info" Variant="Variant.Text" Class="mt-2" Style="border-radius: 12px;">
                                        O módulo de pagamentos via <strong>Stripe</strong> está sendo implementado e estará disponível em breve para gestão completa.
                                    </MudAlert>
                                </MudItem>
                            </MudGrid>
                        </MudTabPanel>
                    </MudTabs>
                </MudCard>
            </MudItem>
            <SettingsHelperSidebar />
        </MudGrid>
    }
</div>

<style>
    .animate-fade-in {
        animation: fadeIn 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>