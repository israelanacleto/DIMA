@page "/settings/me"
@inherits MyAccountPage

<div class="d-flex flex-column gap-y-8 animate-fade-in">
    <!-- Cabeçalho -->
    <div class="d-flex align-center justify-space-between">
        <div>
            <MudText Typo="Typo.h3" Style="font-weight: 700; letter-spacing: -0.02em;">Minha Conta</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mt-1">Gerencie sua conta e segurança</MudText>
        </div>
        <MudButton Variant="Variant.Outlined"
                   StartIcon="@Icons.Material.Outlined.ArrowBack"
                   Color="Color.Secondary"
                   Href="/dashboard"
                   Disabled="IsBusy"
                   Style="border-radius: 10px; text-transform: none; font-weight: 600;">
            Voltar
        </MudButton>
    </div>

    @if (IsBusy && string.IsNullOrEmpty(Email))
    {
        <MudGrid>
            <MudItem xs="12" md="8">
                <MudCard Elevation="4" Style="border-radius: 16px;">
                    <MudCardContent Class="pa-8">
                        <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="400px" />
                    </MudCardContent>
                </MudCard>
            </MudItem>
            <AccountHelperSidebar />
        </MudGrid>
    }
    else
    {
        <MudGrid>
            <MudItem xs="12" md="8">
                <MudCard Elevation="4" Style="border-radius: 16px; overflow: hidden;">
                    <MudTabs Elevation="0"
                             Rounded="true"
                             SliderColor="Color.Primary"
                             ApplyEffectsToContents="true"
                             PanelClass="pa-8">

                        <MudTabPanel Text="Dados Cadastrais" Icon="@Icons.Material.Filled.Person">
                            <EditForm Model="@InputModel" OnValidSubmit="OnValidSubmitAsync">
                                <DataAnnotationsValidator />
                                <MudGrid>
                                    <MudItem xs="12">
                                        <MudText Typo="Typo.caption" Class="ms-1" Style="font-weight: 600;">Conta</MudText>
                                    </MudItem>
                                    <MudItem xs="12" md="6">
                                        <MudTextField Label="E-mail"
                                                      Variant="Variant.Outlined"
                                                      Value="@Email"
                                                      ReadOnly="true"
                                                      FullWidth="true"
                                                      Adornment="Adornment.Start"
                                                      AdornmentIcon="@Icons.Material.Filled.Email" />
                                    </MudItem>
                                    <MudItem xs="12" md="6">
                                        <MudTextField Label="Usuário"
                                                      Variant="Variant.Outlined"
                                                      Value="@UserName"
                                                      ReadOnly="true"
                                                      FullWidth="true"
                                                      Adornment="Adornment.Start"
                                                      AdornmentIcon="@Icons.Material.Filled.AlternateEmail" />
                                    </MudItem>

                                    <MudItem xs="12">
                                        <MudDivider Class="my-2" />
                                    </MudItem>

                                    <MudItem xs="12">
                                        <MudText Typo="Typo.caption" Class="ms-1" Style="font-weight: 600;">Informações Pessoais</MudText>
                                    </MudItem>
                                    <MudItem xs="12" md="8">
                                        <MudTextField Label="Nome Completo"
                                                      Placeholder="Seu nome completo"
                                                      Variant="Variant.Outlined"
                                                      @bind-Value="InputModel.Name"
                                                      For="@(() => InputModel.Name)"
                                                      Adornment="Adornment.Start"
                                                      AdornmentIcon="@Icons.Material.Filled.Badge"
                                                      AdornmentColor="Color.Primary" />
                                    </MudItem>
                                    <MudItem xs="12" md="4">
                                        <MudTextField Label="Telefone"
                                                      Placeholder="(00) 00000-0000"
                                                      Variant="Variant.Outlined"
                                                      @bind-Value="InputModel.PhoneNumber"
                                                      For="@(() => InputModel.PhoneNumber)"
                                                      Adornment="Adornment.Start"
                                                      AdornmentIcon="@Icons.Material.Filled.Phone"
                                                      AdornmentColor="Color.Primary"
                                                      Mask="@(new PatternMask("(00) 00000-0000"))" />
                                    </MudItem>

                                    <MudItem xs="12" Class="mt-4">
                                        <MudButton ButtonType="ButtonType.Submit"
                                                   Variant="Variant.Filled"
                                                   Color="Color.Primary"
                                                   Size="Size.Large"
                                                   FullWidth="true"
                                                   Disabled="IsBusy"
                                                   Style="border-radius: 12px; font-weight: 600; padding: 16px; text-transform: none;">
                                            @if (IsBusy)
                                            {
                                                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                                                <span class="ms-2">Salvando...</span>
                                            }
                                            else
                                            {
                                                <span>Salvar Alterações</span>
                                            }
                                        </MudButton>
                                    </MudItem>
                                </MudGrid>
                            </EditForm>
                        </MudTabPanel>

                        <MudTabPanel Text="Segurança" Icon="@Icons.Material.Filled.Security">
                            <EditForm Model="@PasswordRequest" OnValidSubmit="OnChangePasswordAsync">
                                <DataAnnotationsValidator />
                                <MudGrid>
                                    <MudItem xs="12">
                                        <MudTextField Label="Senha Atual"
                                                      InputType="InputType.Password"
                                                      Placeholder="Digite sua senha atual"
                                                      Variant="Variant.Outlined"
                                                      @bind-Value="PasswordRequest.CurrentPassword"
                                                      For="@(() => PasswordRequest.CurrentPassword)"
                                                      Adornment="Adornment.Start"
                                                      AdornmentIcon="@Icons.Material.Filled.Lock"
                                                      AdornmentColor="Color.Primary" />
                                    </MudItem>

                                    <MudItem xs="12">
                                        <MudDivider Class="my-2" />
                                    </MudItem>

                                    <MudItem xs="12" md="6">
                                        <div class="d-flex flex-column gap-y-2">
                                            <MudTextField Label="Nova Senha"
                                                          InputType="InputType.Password"
                                                          Placeholder="Digite sua nova senha"
                                                          Variant="Variant.Outlined"
                                                          @bind-Value="PasswordRequest.NewPassword"
                                                          For="@(() => PasswordRequest.NewPassword)"
                                                          Adornment="Adornment.Start"
                                                          AdornmentIcon="@Icons.Material.Filled.LockPerson"
                                                          AdornmentColor="Color.Primary"
                                                          Immediate="true"
                                                          OnKeyUp="CheckPasswordStrength" />

                                            @if (!string.IsNullOrEmpty(PasswordRequest.NewPassword))
                                            {
                                                <div class="px-1">
                                                    <div class="d-flex align-center justify-space-between mb-1">
                                                        <MudText Typo="Typo.caption" Color="@StrengthColor">Força da Senha: <strong>@StrengthLabel</strong></MudText>
                                                    </div>
                                                    <MudProgressLinear Color="@StrengthColor"
                                                                       Value="@StrengthValue"
                                                                       Size="Size.Small"
                                                                       Style="border-radius: 4px;" />
                                                </div>
                                            }
                                        </div>
                                    </MudItem>

                                    <MudItem xs="12" md="6">
                                        <MudTextField Label="Confirmar Nova Senha"
                                                      InputType="InputType.Password"
                                                      Placeholder="Confirme sua nova senha"
                                                      Variant="Variant.Outlined"
                                                      @bind-Value="PasswordRequest.ConfirmPassword"
                                                      For="@(() => PasswordRequest.ConfirmPassword)"
                                                      Adornment="Adornment.Start"
                                                      AdornmentIcon="@Icons.Material.Filled.LockClock"
                                                      AdornmentColor="Color.Primary" />
                                    </MudItem>

                                    <MudItem xs="12" Class="mt-4">
                                        <MudButton ButtonType="ButtonType.Submit"
                                                   Variant="Variant.Filled"
                                                   Color="Color.Primary"
                                                   Size="Size.Large"
                                                   FullWidth="true"
                                                   Disabled="IsBusy"
                                                   Style="border-radius: 12px; font-weight: 600; padding: 16px; text-transform: none;">
                                            @if (IsBusy)
                                            {
                                                <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                                                <span class="ms-2">Alterando...</span>
                                            }
                                            else
                                            {
                                                <span>Alterar Senha</span>
                                            }
                                        </MudButton>
                                    </MudItem>
                                </MudGrid>
                            </EditForm>
                        </MudTabPanel>
                    </MudTabs>
                </MudCard>
            </MudItem>
            <AccountHelperSidebar />
        </MudGrid>
    }
</div>

<style>
    .animate-fade-in {
        animation: fadeIn 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>
